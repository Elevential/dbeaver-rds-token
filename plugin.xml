<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <!-- Register the authentication model. -->
    <extension point="org.jkiss.dbeaver.dataSourceAuth">
        <authModel
            id="aws_rds_iam"
            label="AWS RDS IAM"
            description="Authenticate to Amazon RDS using an IAM-generated database auth token instead of a static password."
            class="com.example.dbeaver.ext.rdsiam.RDSIAMAuthModel">
            <!--
              Offer this auth model on RDS-capable datasource providers. The
              mysql provider also covers MariaDB drivers. Add more <datasource>
              lines to enable it elsewhere.
            -->
            <datasource id="postgresql"/>
            <datasource id="mysql"/>
        </authModel>
    </extension>

    <!-- Register the connection-dialog UI panel for the auth model. -->
    <extension point="org.jkiss.dbeaver.ui.propertyConfigurator">
        <propertyConfigurator
            class="com.example.dbeaver.ext.rdsiam.RDSIAMAuthModel"
            uiClass="com.example.dbeaver.ext.rdsiam.ui.RDSIAMAuthConfigurator"/>
    </extension>

</plugin>
